{
  "name": "kitaplik",
  "version": "1.0.0",
  "description": "Kişisel kitap takip uygulaması",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "dist:win": "npm run build && electron-builder --win --dir",
    "pack:win": "powershell -Command \"Compress-Archive -Path release/win-unpacked/* -DestinationPath release/Kitaplik-win.zip -Force\"",
    "postinstall": "echo ok"
  },
  "build": {
    "appId": "com.kitaplik.app",
    "productName": "Kitaplik",
    "asar": true,
    "asarUnpack": [
      "node_modules/sql.js/dist/**"
    ],
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "electron/db/schema.sql",
        "to": "schema.sql"
      }
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "directories": {
      "output": "release"
    }
  },
  "dependencies": {
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^3.9.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "electron": "^31.0.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^5.0.0",
    "postcss": "^8.4.47",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-hook-form": "^7.53.0",
    "react-router-dom": "^6.26.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "zod": "^3.23.0",
    "zustand": "^4.5.0"
  }
}
